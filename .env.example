# FRED API Key — get free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub API key — free at finnhub.io (fallback when Yahoo Finance blocks requests)
FINNHUB_API_KEY=your_finnhub_key_here

# Secret to protect the cron endpoint (generate any random string)
CRON_SECRET=your_random_secret_here
